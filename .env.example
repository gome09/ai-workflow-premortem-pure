# .env.example
#
# 离线演示模式：把 LLM_MODE=mock, STORAGE_BACKEND=sqlite, DEFAULT_SCENARIO_ID=generic_rag_demo 取消注释即可
# ── LLM ──────────────────────────────────────
DEEPSEEK_API_KEY=CHANGE_ME
DEEPSEEK_BASE_URL=https://api.deepseek.com
# DeepSeek V4 official model IDs: deepseek-v4-pro / deepseek-v4-flash
# Stage 1/3 default to Pro + thinking for deeper analysis; Stage 2/4 default to Flash + non-thinking for cost/speed.
MODEL_STAGE_1=deepseek-v4-pro
MODEL_STAGE_2=deepseek-v4-flash
MODEL_STAGE_3=deepseek-v4-pro
MODEL_STAGE_4=deepseek-v4-flash
MODEL_STAGE_1_THINKING=enabled
MODEL_STAGE_2_THINKING=disabled
MODEL_STAGE_3_THINKING=enabled
MODEL_STAGE_4_THINKING=disabled
DEEPSEEK_REASONING_EFFORT=high

# ── 搜索 ─────────────────────────────────────
TAVILY_API_KEY=CHANGE_ME

# ── PostgreSQL ───────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_workflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_DB=0

# ── 应用 ─────────────────────────────────────
APP_ENV=production                      # development / production
LOG_LEVEL=INFO
SESSION_TTL_HOURS=72                    # 会话保留时长
# ── 前端 API 地址 ─────────────────────────────
API_BASE=http://localhost:8000


# ── Workflow Execution ───────────────────────
# json_first keeps schema-first parsing while preserving Markdown fallback.
STAGE_OUTPUT_MODE=json_first

# single_step is the production default.
# langgraph_interrupt is experimental and currently adapter-only.
WORKFLOW_EXECUTION_MODE=single_step

# Domain profile: "default" uses general-purpose prompts and taxonomy.
# "university_ai" loads university AI application risk assessment prompts (Stages 1–4, INIT, REVIEW)
# and extends the risk taxonomy with 6 university-specific types.
# "medical_ai" loads clinical AI governance prompts with HIPAA/FDA SaMD/ISO 14971 focus
# and extends the risk taxonomy with 6 medical-specific types (misdiagnosis, PHI privacy, etc.).
# Any unknown value falls back to "default" silently.
DOMAIN_PROFILE=default
LLM_MODE=real
# LLM_MODE=mock                    # 离线演示，不需要 API Key
STORAGE_BACKEND=postgres
# STORAGE_BACKEND=sqlite            # 不需要 PostgreSQL
# DEFAULT_SCENARIO_ID=generic_rag_demo

# ── Uvicorn ───────────────────────────────────
# 建议值：CPU 核心数 × 2 + 1
UVICORN_WORKERS=2

# === Auth ===
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
FRONTEND_SERVICE_TOKEN=
# Docker Compose 生产部署时 nginx 统一代理，HTTPS 模式需保持 https://localhost
CORS_ALLOW_ORIGINS=https://localhost

# === Data Encryption (T1.3) ===
# Fernet key for field-level encryption of sensitive session data.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty in demo/sqlite mode (plaintext). MUST set in production with storage_backend=postgres.
DATA_ENCRYPTION_KEY=

# === PII Masking (T1.4) ===
# When true, PII (ID card / mobile / email / bank card) is masked before sending to LLM.
# Default false: let detection run first to accumulate false-positive data before enabling.
PII_MASK_BEFORE_LLM=false

# === Data Lifecycle (T1.6) ===
# Audit event retention in days (default 183 = 6 months, aligns with 等保)
AUDIT_RETENTION_DAYS=183
# Session retention in days (0 = forever)
SESSION_RETENTION_DAYS=0
