# .env.demo
#
# 离线演示模式配置，无需真实 API Key 或外部服务
# 适用于：本地演示、论文答辩、功能展示
#
# 使用方式：
#   cp .env.demo .env
#   uv sync --all-extras
#   uv run uvicorn api.main:app --reload --port 8000

# ── LLM ──────────────────────────────────────
LLM_MODE=mock
DEEPSEEK_API_KEY=mock
DEEPSEEK_BASE_URL=https://api.deepseek.com
MODEL_STAGE_1=deepseek-v4-pro
MODEL_STAGE_2=deepseek-v4-flash
MODEL_STAGE_3=deepseek-v4-pro
MODEL_STAGE_4=deepseek-v4-flash
MODEL_STAGE_1_THINKING=enabled
MODEL_STAGE_2_THINKING=disabled
MODEL_STAGE_3_THINKING=enabled
MODEL_STAGE_4_THINKING=disabled
DEEPSEEK_REASONING_EFFORT=high

# ── 搜索 ─────────────────────────────────────
TAVILY_API_KEY=mock

# ── 存储 ─────────────────────────────────────
# SQLite 模式，无需 PostgreSQL
STORAGE_BACKEND=sqlite

# ── 应用 ─────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
SESSION_TTL_HOURS=72

# ── 前端 API 地址 ─────────────────────────────
# 使用 127.0.0.1 而非 localhost：Windows 下 localhost 优先解析 IPv6 (::1)，
# 后端未监听 IPv6 回环地址，会导致每次请求等待约 2 秒的 IPv6 连接超时后才回退到 IPv4。
API_BASE=http://127.0.0.1:8000

# ── Workflow Execution ───────────────────────
STAGE_OUTPUT_MODE=json_first
WORKFLOW_EXECUTION_MODE=single_step
DOMAIN_PROFILE=default
DEFAULT_SCENARIO_ID=generic_rag_demo
UVICORN_WORKERS=1

# ── Auth ─────────────────────────────────────
# 注意：此密钥仅用于本地演示，不应复用于共享环境或生产环境
JWT_SECRET=demo-only-local-secret-32-chars!!
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
FRONTEND_SERVICE_TOKEN=
CORS_ALLOW_ORIGINS=http://localhost:8501,http://localhost:8000
